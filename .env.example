# Environment Variables Template
# Copy this file to .env.local for local development
# Get your Firebase credentials from: https://console.firebase.google.com/project/YOUR_PROJECT/settings/general

# 1. Go to Firebase Console → Project Settings
# 2. Scroll to "Your apps" section
# 3. Select your web app or create a new one
# 4. Copy the configuration values below

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Gemini AI (for chatbot and study materials)
# Get your API key from: https://makersuite.google.com/app/apikey
# 
# OPTION 1: Single API Key (Simple)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
#
# OPTION 2: Multiple API Keys with Auto-Rotation (Recommended for production)
# Separate multiple keys with commas (no spaces)
# The system will automatically rotate keys when one reaches quota limit
# Example: key1,key2,key3
VITE_GEMINI_API_KEYS=your_key_1,your_key_2,your_key_3
#
# Benefits of multiple keys:
# - Automatic failover when quota is reached
# - Higher effective rate limit
# - 1-hour cooldown period before reusing exhausted keys
# - Built-in caching to reduce API calls

